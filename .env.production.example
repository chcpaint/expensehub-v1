# ============================================================================
# expensehub-v1-pilot — live Supabase project credentials
# Copy this file to .env (or set as environment variables in Vercel / Fly).
# Do NOT commit your .env file.
# ============================================================================

# Project URL
SUPABASE_URL=https://uhyfpvhrrkkqbppxfpdr.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://uhyfpvhrrkkqbppxfpdr.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://uhyfpvhrrkkqbppxfpdr.supabase.co

# Publishable (anon) key — safe to ship to the client.
# Use the modern publishable key in new clients; legacy anon JWT is included for
# compatibility libraries that still expect it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_2AYCvf_Grb3xtw9D7Cumcg_YQFKKt8u
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_2AYCvf_Grb3xtw9D7Cumcg_YQFKKt8u
SUPABASE_ANON_KEY=sb_publishable_2AYCvf_Grb3xtw9D7Cumcg_YQFKKt8u

# Service-role key — server-only (worker + edge functions). Get from the
# Supabase dashboard → Settings → API. Never expose to a browser/mobile bundle.
SUPABASE_SERVICE_ROLE_KEY=<COPY FROM DASHBOARD>

# Direct DB connection (used by the Fly worker to LISTEN on pg_notify channels)
SUPABASE_DB_URL=<COPY FROM DASHBOARD → Settings → Database → Connection String>

# OCR & AI — leave blank to use the deterministic stub
GOOGLE_APPLICATION_CREDENTIALS=
DOCUMENT_AI_PROJECT_ID=
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ANTHROPIC_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
