# Supabase (copy from `npx supabase start` output for local development)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<from-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<from-supabase-start>  # server-only, never expose to clients

# Worker secrets (optional — without them the worker uses deterministic stubs)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account.json
DOCUMENT_AI_PROJECT_ID=
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=

# Claude via Bedrock (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ANTHROPIC_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Next.js (web)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from-supabase-start>

# Expo (mobile) — set in apps/mobile/app.json extra.* if you prefer
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=<from-supabase-start>

# Brand / tenant defaults for demo
DEMO_TENANT_NAME="Northridge Construction"
DEMO_TENANT_ACCENT="#1F3A5F"
